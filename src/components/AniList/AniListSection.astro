---
import AniListActivity from "./AniListActivity.astro";
import { fetchAniListSnapshot } from "../../lib/anilist";

const data = await fetchAniListSnapshot();
const currentlyWatching = data.currentlyWatching;
const recentActivity = data.recentActivity;
---

<section aria-label="AniList activity" class="flex flex-col gap-2">
  <h2 class="text-xs font-medium uppercase tracking-wider text-text-muted">anilist activity</h2>

  <div class="border border-border bg-card p-4">
    <div class="mb-3 flex items-center gap-2">
      {currentlyWatching ? (
        <>
          <div class="h-2 w-2 rounded-full bg-accent-green" aria-hidden="true"></div>
          <p class="text-xs text-text-primary">{currentlyWatching}</p>
        </>
      ) : (
        <p class="text-xs text-text-muted">🔴: currently not watching anything</p>
      )}
    </div>

    {recentActivity.length > 0 && (
      <div class="flex flex-col gap-3">
        <div class="border-t border-border"></div>
        {recentActivity.map((activity, index) => (
          <>
            <AniListActivity {activity} />
            {index < recentActivity.length - 1 && (
              <div class="border-t border-border"></div>
            )}
          </>
        ))}
      </div>
    )}
  </div>
</section>