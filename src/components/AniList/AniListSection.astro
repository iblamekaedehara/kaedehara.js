---
import AniListActivity from "./AniListActivity.astro";
import { fetchAniListSnapshot } from "../../lib/anilist";

const data = await fetchAniListSnapshot();
const currentlyWatching = data.currentlyWatching;
const recentActivity = data.recentActivity;
const hasCurrent = currentlyWatching.length > 0;
---

<section aria-label="AniList activity" class="card-shell p-4 sm:p-5">
  <div class="mb-4 flex items-center justify-between gap-4 border-b border-border-soft pb-3">
    <p class="text-xs font-semibold uppercase tracking-wider text-text-muted">anilist activity</p>
  </div>

  <div class="inner-card overflow-hidden">
    <div class="px-4 py-4">
      {hasCurrent ? (
        <div class="flex items-start gap-2.5">
          <div class="mt-1.5 h-2.5 w-2.5 flex-shrink-0 rounded-full bg-accent-green" aria-hidden="true"></div>
          <div class="min-w-0">
            <p class="text-sm font-medium text-text-secondary">currently watching:</p>
            <div class="mt-1 flex flex-col gap-1">
              {currentlyWatching.map((title) => (
                <p class="text-sm font-semibold leading-snug text-text-primary">{title}</p>
              ))}
            </div>
          </div>
        </div>
      ) : (
        <div class="flex items-center gap-2.5">
          <div class="h-2.5 w-2.5 flex-shrink-0 rounded-full bg-accent-red" aria-hidden="true"></div>
          <p class="text-sm font-medium text-text-muted">not watching anything</p>
        </div>
      )}
    </div>

    {recentActivity.length > 0 && (
      <div>
        <div class="border-t border-border-soft"></div>
        {recentActivity.map((activity, index) => (
          <>
            <AniListActivity {activity} />
            {index < recentActivity.length - 1 && (
              <div class="border-t border-border-soft"></div>
            )}
          </>
        ))}
      </div>
    )}
  </div>
</section>
