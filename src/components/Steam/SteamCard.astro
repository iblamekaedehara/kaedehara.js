---
export interface Props {
  name: string;
  playtimeHours: number;
  lastPlayed: string;
  imageUrl: string;
  appid: number;
}

const { name, playtimeHours, lastPlayed, imageUrl, appid } = Astro.props;
---
<a
  href={`https://store.steampowered.com/app/${appid}/`}
  target="_blank"
  rel="noopener noreferrer"
  class="inner-card block overflow-hidden transition duration-200 hover:-translate-y-0.5 hover:bg-card-hover"
>
  <div class="relative w-full border-b border-border-soft" style="aspect-ratio: 3 / 1;">
    <img
      src={imageUrl}
      alt={name}
      class="absolute inset-0 h-full w-full object-cover"
      loading="lazy"
    />
  </div>

  <div class="p-3">
    <p class="truncate text-lg font-semibold leading-tight text-text-primary" title={name}>{name}</p>
    <p class="mt-1 text-sm text-text-secondary">{playtimeHours} hrs on record</p>
    <p class="text-sm text-text-muted">last played {lastPlayed}</p>
  </div>
</a>