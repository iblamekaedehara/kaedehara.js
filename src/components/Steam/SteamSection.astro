---
import SteamCard from "./SteamCard.astro";
import { fetchSteamData } from "../../lib/steam";

const data = await fetchSteamData();
const games = data.games;
const totalPlaytime = data.totalPlaytime;
---

<section aria-label="Steam activity" class="card-shell p-4 sm:p-5">
  <div>
    <div class="mb-4 flex items-center justify-between gap-4 border-b border-border-soft pb-3">
      <p class="text-xs font-semibold uppercase tracking-wider text-text-muted">steam activity</p>
      <p class="text-sm font-medium text-text-secondary">{totalPlaytime} hrs on record</p>
    </div>

    {games.length > 0 ? (
      <div class="flex flex-col gap-3">
        {games.map((game) => (
          <SteamCard
            name={game.name}
            playtimeHours={game.playtimeHours}
            lastPlayed={game.lastPlayed}
            imageUrl={game.imageUrl}
            appid={game.appid}
          />
        ))}
      </div>
    ) : (
      <div class="inner-card py-8 text-center text-sm text-text-secondary">
        <p>No recent Steam activity</p>
        <p class="mt-1 text-xs text-text-muted">Play any game on Steam to see it here</p>
      </div>
    )}
  </div>
</section>
