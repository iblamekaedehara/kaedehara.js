---
import BaseLayout from "../layouts/BaseLayout.astro";
import PresenceSection from "../components/Presence/PresenceSection.svelte";
import SteamSection from "../components/Steam/SteamSection.astro";
import AniListSection from "../components/AniList/AniListSection.astro";
---

<BaseLayout>
  <main class="mx-auto flex min-h-screen max-w-[580px] flex-col px-4 py-6 md:px-6 md:py-10">
    <!-- Hydrated presence section: avatar, status, Discord rich presence cards, social links -->
    <PresenceSection client:load />

    <!-- Steam section -->
    <div class="mt-6">
      <SteamSection />
    </div>

    <!-- AniList section -->
    <div class="mt-6">
      <AniListSection />
    </div>
  </main>
</BaseLayout>